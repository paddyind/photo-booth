# Copy to `.env.standalone` in the repo root (gitignored).
# Simple start/stop/restart for events: see scripts/PHOTO-BOOTH-END-USER-START.txt
# Loaded automatically by `scripts/run-api-standalone.sh` and `scripts/run-api-standalone.bat`.
# One command starts API + print watcher together (scripts/photo_booth_standalone.py).
# When the server starts, the console prints how to test from your phone: open http://<LAN>:<PORT>/health
# in the phone browser (expect JSON "status":"ok"). Windows step-by-step: scripts/README-WINDOWS-STANDALONE.txt

# --- API (optional overrides; same as shell env) ---
# Default port for mobile PHOTOBOOTH_API_BASE (e.g. http://192.168.1.5:8001):
API_PORT=8001
#
# By default the server does NOT switch to 8002+ if 8001 is busy — it stops whatever is
# listening on API_PORT and binds there (Windows + Mac/Linux). Rebuild the app once for :8001.
#
# Legacy: allow 8002, 8003… if busy (you must change PHOTOBOOTH_API_BASE when the port changes):
# PHOTOBOOTH_PORT_FALLBACK=1
#
# With PHOTOBOOTH_PORT_FALLBACK=1 only: fail immediately if API_PORT busy instead of scanning:
# PHOTOBOOTH_STRICT_PORT=1
#
# Windows: if bind still fails with WinError 10013 (Hyper-V excluded range), try another API_PORT e.g. 18080
# Where session folders, finals, and print-queue live (must match PHOTOBOOTH_DATA_DIR unless you override paths below):
DATA_DIR=./data-standalone
# FRAMES_DIR=./shared/frames

# --- Printer + print-queue → print → print-archive (recommended) ---
# Exact queue name (must match OS). Windows: powershell -File scripts/list-printers.ps1
# Mac/Linux: ./scripts/list-printers.sh  or  lpstat -p
PHOTOBOOTH_PRINTER_NAME="EPSON L3250 Series"

# Watch print-queue only; after each successful print, file is moved to print-archive (never printed twice).
PHOTOBOOTH_PRINT_WATCH_MODE=queue

# After each POST /compose/final, copy a unique file into print-queue (watcher picks it up).
# Original final remains under …/finals/ for the app URL/download.
PHOTOBOOTH_COPY_FINAL_TO_PRINT_QUEUE=1

# Watcher data root (defaults to DATA_DIR). Keep equal to DATA_DIR unless you use a custom layout.
# PHOTOBOOTH_DATA_DIR=./data-standalone

# Optional: override queue/archive folders (defaults: DATA_DIR/print-queue and DATA_DIR/print-archive)
# PHOTOBOOTH_PRINT_QUEUE_DIR=
# PHOTOBOOTH_PRINT_ARCHIVE_DIR=

# Only if you want printing OFF while keeping the name above:
# PHOTOBOOTH_ENABLE_PRINT_WATCHER=0
