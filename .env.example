# Docker maps host API_PORT -> container 8000 (default 8000).
API_PORT=8000
WEB_PORT=3000
# Standalone script default is 8001 (override: API_PORT=8002 ./scripts/run-api-standalone.sh).
# Standalone uses ./data-standalone by default so it can run next to Docker ./data without clashes.
# Backend data persists on the HOST at ./data when using docker-compose (volume mount). Restarting the container does not delete ./data.
DATA_DIR=./data
FRAMES_DIR=./shared/frames
DEFAULT_PRINT_SIZE=4x6
PRINT_W_4X6=1800
PRINT_H_4X6=2700

# --- Mobile bundle (prepare-www) — used when building apps/mobile/www before cap sync ---
# Capacitor Filesystem Directory: DOCUMENTS | DATA | CACHE | LIBRARY | EXTERNAL | EXTERNAL_STORAGE
PHOTOBOOTH_FS_DIRECTORY=DOCUMENTS
# Relative paths under that directory (use forward slashes). Point finals at a folder Syncthing syncs to your laptop for printing.
PHOTOBOOTH_SAVE_PATH_ORIGINALS=PhotoBooth/originals
PHOTOBOOTH_SAVE_PATH_FINALS=PhotoBooth/finals
# Example for Android + Syncthing (adjust to a path your device exposes to Syncthing):
# PHOTOBOOTH_FS_DIRECTORY=EXTERNAL
# PHOTOBOOTH_SAVE_PATH_ORIGINALS=DCIM/photobooth/camera
# PHOTOBOOTH_SAVE_PATH_FINALS=DCIM/photobooth/print_queue
