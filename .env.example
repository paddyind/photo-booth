# Docker maps host API_PORT -> container 8000 (default 8000).
API_PORT=8000
WEB_PORT=3000
# Standalone script default is 8001 (override: API_PORT=8002 ./scripts/run-api-standalone.sh).
# Standalone uses ./data-standalone by default so it can run next to Docker ./data without clashes.
# Backend data persists on the HOST at ./data when using docker-compose (volume mount). Restarting the container does not delete ./data.
DATA_DIR=./data
FRAMES_DIR=./shared/frames
DEFAULT_PRINT_SIZE=4x6
PRINT_W_4X6=1800
PRINT_H_4X6=2700

# --- Mobile bundle (prepare-www) — used when building apps/mobile/www before cap sync ---
# EXTERNAL_STORAGE + Download → user-visible path like /storage/emulated/0/Download/PhotoBooth_YYYYMMDD/
# (good for Samsung My Files + Syncthing). DOCUMENTS = app-private sandbox (harder to sync).
PHOTOBOOTH_FS_DIRECTORY=EXTERNAL_STORAGE
# Parent folder only; the app always adds PhotoBooth_YYYYMMDD (persisted — same folder after APK updates).
PHOTOBOOTH_SAVE_PATH=Download
# Use My Files → Documents instead of Download:
# PHOTOBOOTH_SAVE_PATH=Documents
# App-private only (no public Download path):
# PHOTOBOOTH_FS_DIRECTORY=DOCUMENTS
# PHOTOBOOTH_SAVE_PATH=
