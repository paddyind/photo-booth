# Copy this file to `env.build` in the same folder and edit values.
# Then run:  ./build-booth.sh   (Mac/Linux) or  build-booth.bat  (Windows)
#
# REQUIRED: your booth PC’s LAN IPv4 + standalone API port (default 8001).
# Do not use 127.0.0.1 — on the phone that is the phone itself.
#
PHOTOBOOTH_API_BASE=http://192.168.0.1:8001

# Use the host print_watcher + print-queue only (no browser print tab on the phone).
PHOTOBOOTH_SUPPRESS_REAR_BROWSER_PRINT=1

# Optional: show API ping panel (remove or set to 0 once stable).
# PHOTOBOOTH_CONNECTIVITY_DEBUG=1
